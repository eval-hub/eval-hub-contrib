FROM registry.access.redhat.com/ubi9/python-312:latest

# Pinned upstream commit — bump this ARG to update RULER scripts.
# To find the current HEAD: gh api repos/nvidia/RULER/commits/main --jq '.sha'
ARG RULER_COMMIT=ab17b7853df4e0a30b78cd5d2b463ac7dff6ee13

# Install system dependencies
USER 0
RUN dnf install -y git && dnf clean all

WORKDIR /app

# Fetch only the scripts subtree from NVIDIA/RULER at the pinned commit.
# No RULER source files are stored in this repository.
RUN git clone --no-checkout --filter=blob:none \
        https://github.com/NVIDIA/RULER /opt/ruler-upstream && \
    git -C /opt/ruler-upstream sparse-checkout init --cone && \
    git -C /opt/ruler-upstream sparse-checkout set scripts && \
    git -C /opt/ruler-upstream checkout "$RULER_COMMIT" && \
    rm -rf /opt/ruler-upstream/.git

# Copy requirements and install via standard pip
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application files (no scripts/ — they live in /opt/ruler-upstream/scripts)
COPY main.py .
COPY provider.yaml .
COPY .dockerignore .

# COPY dummy job spec for local testing / default behavior
COPY meta/job.json /meta/job.json

# Setup runtime environment
RUN mkdir -p /tmp/.ruler_cache && \
    chmod -R 777 /tmp && \
    chown -R 1001:0 /app && \
    chmod -R g+rwX /app && \
    chown -R 1001:0 /opt/app-root && \
    chmod -R g+rwX /opt/app-root

ENV PYTHONUNBUFFERED=1
ENV EVALHUB_MODE=k8s
ENV HOME=/tmp
ENV HF_HOME=/tmp/.huggingface
ENV TOKENIZERS_PARALLELISM=true
ENV RULER_SCRIPTS_DIR=/opt/ruler-upstream/scripts

USER 1001

ENTRYPOINT ["python", "main.py"]
