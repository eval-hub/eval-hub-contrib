# Inspect AI adapter container for eval-hub
FROM registry.access.redhat.com/ubi9/python-312:latest

USER 0

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY *.py .

RUN mkdir -p /tmp/.inspect_cache && \
    chmod -R 777 /tmp && \
    chown -R 1001:0 /app && \
    chmod -R g+rwX /app && \
    chown -R 1001:0 /opt/app-root && \
    chmod -R g+rwX /opt/app-root

ENV PYTHONUNBUFFERED=1
ENV EVALHUB_MODE=k8s
ENV HOME=/tmp
# Disable Inspect AI telemetry in container
ENV INSPECT_NO_TELEMETRY=1

USER 1001

ENTRYPOINT ["python", "main.py"]
