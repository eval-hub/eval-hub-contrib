# Copy to .env in this folder. Do not commit .env.

# One model: same URL + name for local CLEAR (Part A) and for SDK/curl (Part B).
MODEL_URL=http://127.0.0.1:8000/v1
MODEL_NAME=example-model

# Only if you use inference_backend=litellm (locally or in job JSON). With endpoint + MODEL_URL, omit.
# OPENAI_API_KEY=

EVALHUB_URL=
EVALHUB_TOKEN=
EVALHUB_TENANT=

NAMESPACE=

S3_BUCKET=
# Prefix in the bucket where *.json traces live, e.g. traces/
S3_PREFIX=traces/
S3_SECRET_REF=

# MLflow experiment name (Part B curl default ${EXPERIMENT_NAME:-…} and SDK)
EXPERIMENT_NAME=clear-agentic-mlflow-exp

# JOB_NAME=clear-evalhub-job-1
